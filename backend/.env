# Copia este archivo como .env y completa los valores
# cp .env.example .env

# Clave de API de Anthropic — ya no se usa aquí.
# El usuario la ingresa en la interfaz (Configuración) y se guarda solo en su navegador.
# ANTHROPIC_API_KEY=

# Puerto del servidor Express (opcional, por defecto 3001)
PORT=3001

# Origen permitido por CORS (desarrollo: localhost:5173 | producción: https://tu-dominio.com)
CORS_ORIGIN=http://localhost:5173
